# TARA environment variables.
# Copy to .env.local and fill in.

# Convex deployment backing the catalogue, orders, verifications, and
# loyalty data. Run `npx convex dev` once to generate these for your own
# deployment, or copy them from an existing one.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# --- Not yet wired (future) ---
# SumUp secret key for live checkout (server-side only — never expose). See convex/SUMUP.md.
# SUMUP_SECRET_KEY=
