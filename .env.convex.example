# Convex backend environment variables.
# Set on your deployment with:
#   npx convex env set --from-file .env.convex
#   npx convex env set --from-file .env.convex --prod   # production
#
# Copy and fill in real values:
#   cp .env.convex.example .env.convex

# SumUp secret API key — server-side only (see convex/SUMUP.md)
SUMUP_SECRET_KEY=replace-with-sumup-sandbox-secret-key

# Optional: SumUp webhook signing secret (when webhook handler is implemented)
# SUMUP_WEBHOOK_SECRET=

# Auth keys — generated by `npx @convex-dev/auth` when auth is set up
# JWT_PRIVATE_KEY=
# JWKS=
