# Peppy storefront environment variables.
# Copy to .env.local and fill in. All are optional — the app builds and runs
# without them (analytics simply stays off, verification meta is omitted).

# Google Analytics 4 measurement ID, e.g. G-XXXXXXXXXX.
# Leave unset to disable analytics entirely.
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token — the `content` value of the
# google-site-verification meta tag Search Console gives you.
GOOGLE_SITE_VERIFICATION=

# --- Not yet wired (future) ---
# Stripe secret key for live checkout (server-side only — never expose).
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
