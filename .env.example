# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# Convex dashboard: https://dashboard.convex.dev/t/boundless-synergy/peppy-c3b07

# --- Convex (Next.js client) ---
# Dev deployment — used by `npm run dev`
CONVEX_DEPLOYMENT=dev:dependable-vulture-853
NEXT_PUBLIC_CONVEX_URL=https://dependable-vulture-853.eu-west-1.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://dependable-vulture-853.eu-west-1.convex.site

# Deploy key for CI / `npx convex deploy` (create with: npx convex deployment token create <name> --save-env)
# CONVEX_DEPLOY_KEY=dev:dependable-vulture-853|<token>

# --- Production Convex (Vercel / hosting) ---
# Prod deployment URLs (set these in your hosting provider's env settings)
# NEXT_PUBLIC_CONVEX_URL=https://patient-wildebeest-774.eu-west-1.convex.cloud
# NEXT_PUBLIC_CONVEX_SITE_URL=https://patient-wildebeest-774.eu-west-1.convex.site
# CONVEX_DEPLOY_KEY=prod:patient-wildebeest-774|<token>   # CI only — never expose in the browser

# --- SumUp (client — if using the payment widget) ---
# NEXT_PUBLIC_SUMUP_MERCHANT_CODE=

# --- Auth (when @convex-dev/auth is added) ---
# JWT_PRIVATE_KEY and JWKS are generated by `npx @convex-dev/auth` — store on Convex, not here.
